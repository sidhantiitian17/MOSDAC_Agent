# LLM — LongCat (OpenAI-compatible). Swap base_url + model to use local Docker model (Ollama, vLLM, etc).
LONGCAT_API_KEY=your_longcat_api_key_here
LONGCAT_MODEL=LongCat-Flash-Chat
LONGCAT_API_BASE=https://api.longcat.chat/openai
LONGCAT_API_FORMAT=openai

# Embeddings — Gemini
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_API_KEY=your_gemini_api_key_here

NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_API_KEY=your_nvidia_api_key_here


# Neo4j
NEO4J_ID=your_neo4j_instance_id_here
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_neo4j_password_here
NEO4J_DATABASE=neo4j
NEO4J_PATH=/path/to/neo4j/data/directory
NEO4J_VERSION=2026.04.0

# ChromaDB
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=graph_rag

# OCR (Tesseract + Poppler) — used as fallback for image-only PDFs
TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
POPPLER_PATH=C:/path/to/poppler/bin

# Data sources
DOWNLOADS_DIR=D:/AI_agents/downloads
ATLASES_DIR=D:/AI_agents/atlases_pdfs

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# Retrieval
TOP_K_VECTOR=5
TOP_K_GRAPH=10
GRAPH_DEPTH=2
