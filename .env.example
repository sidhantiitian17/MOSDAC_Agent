# ═══════════════════════════════════════════════════════════════════════
# MOSDAC GraphRAG — Configuration TEMPLATE
# Copy this file to .env and fill in real values. .env is git-ignored so
# secrets never reach the repo. Every credential is loaded from .env only —
# nothing is hardcoded in source.
# ═══════════════════════════════════════════════════════════════════════

# ── LLM: Tabby ML (OpenAI-compatible) ──────────────────────────────────
# HOME DEVELOPMENT SETUP (active)
TABBY_BASE_URL=http://localhost:8080/v1
TABBY_API_TOKEN=your_tabby_token_here
TABBY_MODEL=Qwen2-1.5B-Instruct

# ISRO PRODUCTION SETUP — comment the 3 home lines above, uncomment these:
# TABBY_BASE_URL=http://192.168.100.101:8080/v1
# TABBY_API_TOKEN=your_isro_tabby_token_here
# TABBY_MODEL=Qwen2-1.5B-Instruct

# ── Knowledge-graph extraction LLM ──────────────────────────────────────
# How triples are mined from each chunk: llm | spacy | auto
EXTRACTION_BACKEND=auto
# SWITCH THE EXTRACTION MODEL HERE — set to any model Tabby ML is serving.
# Leave blank to reuse TABBY_MODEL. Change this one line to use a bigger/better
# model for knowledge-graph extraction without editing any code.
TABBY_EXTRACTION_MODEL=
# Point extraction at a SEPARATE server only if needed (defaults to TABBY_*):
# EXTRACTION_LLM_BASE_URL=http://localhost:8080/v1
# EXTRACTION_LLM_API_TOKEN=your_token_here
EXTRACTION_TEMPERATURE=0.0
EXTRACTION_MAX_TOKENS=1536

# Chat LLM generation settings (shared by all get_llm() callers)
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2048

# When running chat_api inside docker compose, the container cannot reach
# host-local services via localhost. Override to use host.docker.internal
# (default) or a LAN address for air-gapped ISRO environments:
# TABBY_BASE_URL_DOCKER=http://host.docker.internal:8080/v1
# OLLAMA_BASE_URL_DOCKER=http://host.docker.internal:11434

# ── Embeddings — bge-large via Ollama ──────────────────────────────────
# The endpoint and model come from .env only — never hardcoded in source.
# The embedder appends /api/embeddings to OLLAMA_BASE_URL automatically.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-large
# bge-style asymmetric retrieval: the QUERY gets this instruction prefix while
# passages stay bare (improves recall). Set empty for a symmetric model.
EMBED_QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:

# ── Neo4j (container runs NEO4J_AUTH=none — these creds are ignored) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=dummy
NEO4J_DATABASE=neo4j

# ── System prompt (edit the file to change LLM behaviour, no code change) ─
SYSTEM_PROMPT_PATH=./prompts/system_prompt.txt

# ── ChromaDB (local vector store) ──────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=graph_rag

# ── OCR (Tesseract + Poppler) — fallback for image-only PDFs ───────────
# Leave both empty (default) on Linux/macOS — install binaries via package
# manager and they will be found on PATH automatically:
#   Linux:  apt-get install tesseract-ocr poppler-utils
#   macOS:  brew install tesseract poppler
# On Windows, install the binaries and set the paths explicitly:
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# POPPLER_PATH=C:/path/to/poppler/bin

# ── Docling (primary PDF parser — structured Markdown + LaTeX math + OCR) ───
# Set USE_DOCLING=false to revert to the legacy pypdf/PyMuPDF/OCR cascade only.
USE_DOCLING=true
# Path substrings that force full-page OCR (raster atlas PDFs have labels
# burned into imagery — a text-layer check would miss them entirely).
DOCLING_FORCE_FULL_PAGE_OCR_DIRS=atlases_pdfs
# Tesseract language code — must match installed tessdata package (tesseract-ocr-eng → eng).
DOCLING_OCR_LANG=eng
# Extract display formulas as $$...$$ LaTeX (uses CPU CodeFormula model).
# Set false on very constrained hardware — OCR and tables still work without it.
DOCLING_DO_FORMULA_ENRICHMENT=true
# Parse tables into structured Markdown (TableFormer model).
DOCLING_DO_TABLE_STRUCTURE=true
# Files larger than this MB skip Docling and use the streaming OCR fallback
# instead — prevents OOM on the 407 MB Images_of_Moon atlas.
DOCLING_MAX_FILE_MB=250
# Max pages per document parsed by Docling (0 = no cap).
DOCLING_MAX_PAGES=0

# ── Universal multi-format ingestion ───────────────────────────────────────
# Kill-switches for whole format families. Routing lives in the registry
# (graph_rag/ingestion/formats.py); flip these to stop discovering/parsing a
# category with no code change. Core PDF/HTML/text are always enabled.
INGEST_ENABLE_OFFICE=true     # .docx / .xlsx / .pptx / .csv / .adoc
INGEST_ENABLE_IMAGES=true     # .png / .jpg / .tiff / .bmp / .webp / .gif (OCR)
# Skip images larger than this many MB (OCR OOM guard).
INGEST_IMAGE_MAX_MB=50

# Garbage-data quality gate — rejects low-signal extractions (blank scans, empty
# sheets, decorative GIFs, OCR gibberish) before embedding/KG. Tune for a noisy
# corpus without code edits. Math ($$...$$) is exempt from the alnum check.
INGEST_MIN_CHARS=40                # drop near-empty extractions
INGEST_MIN_ALNUM_RATIO=0.50        # drop OCR gibberish / binary noise
INGEST_MIN_UNIQUE_TOKENS=8         # drop degenerate repetition
INGEST_MAX_REPEAT_RATIO=0.40       # drop "the the the…" loops
INGEST_MAX_REPLACEMENT_RATIO=0.10  # drop replacement/control-char soup

# Production switch: when deploying with Qwen 2.5 Coder 32B, update TABBY_MODEL:
# TABBY_MODEL=Qwen2.5-Coder-32B-Instruct

# ── Drupal JSON:API source (drupal_ingest.py) ────────────────────────────
# Set these to enable Drupal → Graph RAG incremental ingestion.
# DB settings (ChromaDB, Neo4j, embedder) are shared with the section above.
DRUPAL_JSONAPI_URL=http://my-drupal-site.ddev.site/jsonapi/node/article
DRUPAL_USERNAME=api_user
DRUPAL_PASSWORD=change-me
# Optional — defaults shown:
# DRUPAL_STATE_PATH=drupal_ingestion_state.json
# DRUPAL_PAGE_SIZE=50
# DRUPAL_REQUEST_TIMEOUT=30
# DRUPAL_KG_MIN_CONFIDENCE=0.6

# ── Data sources ────────────────────────────────────────────────────────
DOWNLOADS_DIR=./downloads
ATLASES_DIR=./atlases_pdfs

# Incremental ingestion: content-hash manifest of already-ingested files.
# Files whose SHA-256 hash is recorded here are skipped on re-runs (use
# `python main.py ingest --force` to re-ingest everything).
INGEST_MANIFEST_PATH=./ingest_manifest.json

# ── Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
# Sections longer than this many chars are sub-split (math/table-safe, overlapped)
# so they fit the embedder's context window and stay fully searchable.
CHUNK_MAX_SECTION_CHARS=1600
ENABLE_SECTION_SUBSPLIT=true

# ── Retrieval ────────────────────────────────────────────────────────────
TOP_K_VECTOR=5
TOP_K_GRAPH=10
GRAPH_DEPTH=2
TOP_K_BM25=5
HYBRID_RRF_K=60

# ── Formula / quantitative precision ───────────────────────────────────────
# Inject chunks containing the verbatim symbol run for math queries (exact match).
ENABLE_EXACT_FORMULA_MATCH=true
# Nudge formula / numeric-dense chunks up the ranking for numeric/formula queries.
ENABLE_FEATURE_BOOST=true
FEATURE_BOOST_WEIGHT=0.25
# Show the LLM the full parent section while grounding on the precise child chunk.
# Requires a re-ingest (chunks must carry parent_id). OFF keeps current behaviour.
ENABLE_PARENT_EXPANSION=false

# ── Cross-encoder rerank (optional — stronger than the bi-encoder re-sort) ──
# When on AND a reranker endpoint is set, the fused pool is re-scored by a
# cross-encoder; otherwise the bi-encoder cosine rerank is used. Auto-falls back
# to the bi-encoder if the endpoint is unreachable.
ENABLE_CROSS_ENCODER_RERANK=false
RERANKER_BASE_URL=
RERANKER_MODEL=
RERANKER_API_TOKEN=

# ── Output grounding enforcement (anti-hallucination, L4) ───────────────────
# What to do with ungrounded numbers/sentences in the model's answer:
#   flag   — log only (legacy; hallucinations still reach the user)
#   strip  — remove ungrounded sentences; refuse if too little survives
#   refuse — any ungrounded content → canonical "no info" refusal
GUARD_GROUNDING_ACTION=strip
GUARD_GROUNDING_MAX_UNGROUNDED_RATIO=0.5

# ── RAGAS evaluation gate (evaluation_plan.md — `python main.py ragas-eval`) ─
# The judge is the measuring instrument: it MUST be a stronger model than the
# local generator under test, never the same one (§4.1). Point these at any
# OpenAI-compatible chat + embeddings endpoint (a frontier model is recommended).
# Leave RAGAS_JUDGE_MODEL empty to skip — the gate will refuse to score without it.
RAGAS_JUDGE_MODEL=Qwen2.5-Coder-32B-Instruct
RAGAS_JUDGE_BASE_URL=http://localhost:8080/v1
RAGAS_JUDGE_API_KEY=your_tabby_token_here
RAGAS_JUDGE_EMBED_MODEL=bge-large
RAGAS_JUDGE_EMBED_BASE_URL=http://localhost:11434
RAGAS_JUDGE_EMBED_API_KEY=

# ── History-aware retrieval & answer quality ─────────────────────────────
# Rewrite follow-ups ("what's its resolution?") into a standalone query using
# recent turns before retrieval. Gated: the LLM rewrite fires only on detected
# follow-ups, so most turns cost nothing.
ENABLE_QUERY_CONTEXTUALIZATION=true
CONTEXTUALIZER_MAX_HISTORY_CHARS=1500
# Embedding-rerank the fused vector+BM25 passages, keep the most relevant few.
ENABLE_PASSAGE_RERANK=true
RERANK_CANDIDATE_POOL=20
TOP_K_PASSAGES=6
# Rolling summary of older turns once history exceeds the recent window (opt-in,
# adds an LLM call on overflow only).
ENABLE_CONVERSATION_SUMMARY=false
SUMMARY_KEEP_RECENT_TURNS=6

# ── ChatAPI gateway (FastAPI HTTP layer — branding, CORS, sessions) ────
CHAT_API_TITLE=Graph RAG Chatbot API
CHAT_API_VERSION=1.0.0
CHAT_API_BOT_NAME=Assistant
# CORS — exact-match per origin including port. No wildcards in production.
# Dev: add any frontend port you use locally (3000 = React/Next.js, 5173 = Vite).
# Prod: include all MOSDAC domains served from the browser. Add subdomains as needed,
#   e.g. https://vedas.mosdac.gov.in
CHAT_API_ALLOWED_ORIGINS=http://localhost,http://localhost:3000,http://localhost:5173,http://localhost:8080,http://127.0.0.1,http://127.0.0.1:3000,https://mosdac.gov.in,https://www.mosdac.gov.in
CHAT_API_ALLOWED_METHODS=GET,POST,OPTIONS
CHAT_API_ALLOWED_HEADERS=Content-Type,Authorization,Accept
CHAT_API_MAX_HISTORY_TURNS=10
# Sessions: "memory" (dev / single replica) or "redis" (multi-replica, persistent).
# PRODUCTION: use redis. Set REQUIRE_PERSISTENT_SESSIONS=true to refuse the memory
# backend so a multi-worker deploy never silently splits session state.
CHAT_API_SESSION_BACKEND=memory
CHAT_API_REDIS_URL=
CHAT_API_REQUIRE_PERSISTENT_SESSIONS=false
# Idle-session TTL (seconds) + in-memory LRU cap — bound memory & set a retention
# boundary for stored (PII-redacted) turns. Enforced for BOTH backends.
CHAT_API_SESSION_TTL_SECONDS=86400
CHAT_API_MAX_SESSIONS=50000
# Multimodal: keep screenshots OFF until a vision-capable model is wired — the
# default chat model is text-only. Set CHAT_API_VISION_MODEL to the VLM id when ready.
CHAT_API_ENABLE_SCREENSHOT=true
CHAT_API_MAX_SCREENSHOT_BYTES=8388608
CHAT_API_VISION_MODEL=
CHAT_API_HOST=0.0.0.0
CHAT_API_PORT=8000

# ── ChatAPI hardening (production.md) ──────────────────────────────────
# Request limits (P1-2): reject oversized bodies / messages at the edge.
CHAT_API_MAX_REQUEST_BYTES=12582912
CHAT_API_MAX_MESSAGE_CHARS=8000
# Optional caller auth (P1-1): when set, /chat requires X-API-Key or Bearer token.
CHAT_API_API_KEY=
# Trust X-Forwarded-For for per-IP rate limiting (ONLY behind a trusted proxy/LB).
CHAT_API_TRUST_FORWARDED_FOR=false
# Observability + ops.
CHAT_API_ENABLE_METRICS=true
# Operator token guarding POST /reload (BM25/corpus hot-reload). Empty = endpoint off.
CHAT_API_ADMIN_TOKEN=
# Optional answer cache for repeated FAQ questions (grounded answers only).
CHAT_API_ENABLE_ANSWER_CACHE=false
CHAT_API_ANSWER_CACHE_SIZE=1000
CHAT_API_ANSWER_CACHE_TTL_SECONDS=3600

# ── Embedding throughput (P0-1) ────────────────────────────────────────
OLLAMA_USE_NATIVE_BATCH=true
OLLAMA_EMBED_BATCH_PATH=/api/embed
OLLAMA_EMBED_BATCH_SIZE=64
EMBED_QUERY_CACHE_SIZE=512
EMBED_TIMEOUT_SECONDS=120

# ── LLM resilience (P1-5) ──────────────────────────────────────────────
LLM_REQUEST_TIMEOUT=60
LLM_MAX_RETRIES=2
LLM_MAX_CONCURRENCY=8

# ── Neo4j driver pool (P2-4) ───────────────────────────────────────────
NEO4J_MAX_POOL_SIZE=50
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_MAX_CONNECTION_LIFETIME=3600

# ── BM25 keyword index (P1-4) ──────────────────────────────────────────
# Rebuild the in-memory keyword index when the corpus changes (re-ingest).
BM25_AUTO_REFRESH=true

# ── Guardrail hardening (production.md) ────────────────────────────────
# Fail CLOSED (refuse) while the embedder is down instead of failing open. The
# degradation is ALWAYS observable via the guardrail_degraded_total metric.
GUARD_EMBEDDER_REQUIRED=false
# Neutralize injection directives smuggled inside retrieved documents (P1-3).
GUARD_CONTEXT_INJECTION_SCAN=true
# Optional: externalize the domain scope seeds to a file (one phrase per line) so
# the SAME image serves a non-MOSDAC domain without a code change (P2-1).
GUARD_SCOPE_SEED_PATH=
# Durable, queryable audit sink (PII-safe). Empty = stdout logger only.
GUARD_AUDIT_LOG_PATH=
GUARD_AUDIT_LOG_MAX_BYTES=52428800
GUARD_AUDIT_LOG_BACKUPS=5
