# ═══════════════════════════════════════════════════════════════════════
# MOSDAC GraphRAG — Configuration TEMPLATE
# Copy this file to .env and fill in real values. .env is git-ignored so
# secrets never reach the repo. Every credential is loaded from .env only —
# nothing is hardcoded in source.
# ═══════════════════════════════════════════════════════════════════════

# ── LLM: Tabby ML (OpenAI-compatible) ──────────────────────────────────
# HOME DEVELOPMENT SETUP (active)
TABBY_BASE_URL=http://localhost:8080/v1
TABBY_API_TOKEN=your_tabby_token_here
TABBY_MODEL=Qwen2-1.5B-Instruct

# ISRO PRODUCTION SETUP — comment the 3 home lines above, uncomment these:
# TABBY_BASE_URL=http://192.168.100.101:8080/v1
# TABBY_API_TOKEN=your_isro_tabby_token_here
# TABBY_MODEL=Qwen2-1.5B-Instruct

# ── Knowledge-graph extraction LLM ──────────────────────────────────────
# How triples are mined from each chunk: llm | spacy | auto
EXTRACTION_BACKEND=auto
# SWITCH THE EXTRACTION MODEL HERE — set to any model Tabby ML is serving.
# Leave blank to reuse TABBY_MODEL. Change this one line to use a bigger/better
# model for knowledge-graph extraction without editing any code.
TABBY_EXTRACTION_MODEL=
# Point extraction at a SEPARATE server only if needed (defaults to TABBY_*):
# EXTRACTION_LLM_BASE_URL=http://localhost:8080/v1
# EXTRACTION_LLM_API_TOKEN=your_token_here
EXTRACTION_TEMPERATURE=0.0
EXTRACTION_MAX_TOKENS=1536

# When running chat_api inside docker compose, the container cannot reach a
# host-local Tabby via localhost. Override if Tabby is on a LAN address:
# TABBY_BASE_URL_DOCKER=http://host.docker.internal:8080/v1

# ── Embeddings — bge-large via Ollama ──────────────────────────────────
# The endpoint and model come from .env only — never hardcoded in source.
# The embedder appends /api/embeddings to OLLAMA_BASE_URL automatically.
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=bge-large

# ── Neo4j (container runs NEO4J_AUTH=none — these creds are ignored) ───
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=dummy
NEO4J_DATABASE=neo4j

# ── System prompt (edit the file to change LLM behaviour, no code change) ─
SYSTEM_PROMPT_PATH=./prompts/system_prompt.txt

# ── ChromaDB (local vector store) ──────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=graph_rag

# ── OCR (Tesseract + Poppler) — fallback for image-only PDFs ───────────
# Leave both empty (default) on Linux/macOS — install binaries via package
# manager and they will be found on PATH automatically:
#   Linux:  apt-get install tesseract-ocr poppler-utils
#   macOS:  brew install tesseract poppler
# On Windows, install the binaries and set the paths explicitly:
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe
# POPPLER_PATH=C:/path/to/poppler/bin

# ── Docling (primary PDF parser — structured Markdown + LaTeX math + OCR) ───
# Set USE_DOCLING=false to revert to the legacy pypdf/PyMuPDF/OCR cascade only.
USE_DOCLING=true
# Path substrings that force full-page OCR (raster atlas PDFs have labels
# burned into imagery — a text-layer check would miss them entirely).
DOCLING_FORCE_FULL_PAGE_OCR_DIRS=atlases_pdfs
# Tesseract language code — must match installed tessdata package (tesseract-ocr-eng → eng).
DOCLING_OCR_LANG=eng
# Extract display formulas as $$...$$ LaTeX (uses CPU CodeFormula model).
# Set false on very constrained hardware — OCR and tables still work without it.
DOCLING_DO_FORMULA_ENRICHMENT=true
# Parse tables into structured Markdown (TableFormer model).
DOCLING_DO_TABLE_STRUCTURE=true
# Files larger than this MB skip Docling and use the streaming OCR fallback
# instead — prevents OOM on the 407 MB Images_of_Moon atlas.
DOCLING_MAX_FILE_MB=250
# Max pages per document parsed by Docling (0 = no cap).
DOCLING_MAX_PAGES=0

# Production switch: when deploying with Qwen 2.5 Coder 32B, update TABBY_MODEL:
# TABBY_MODEL=Qwen2.5-Coder-32B-Instruct

# ── Drupal JSON:API source (drupal_ingest.py) ────────────────────────────
# Set these to enable Drupal → Graph RAG incremental ingestion.
# DB settings (ChromaDB, Neo4j, embedder) are shared with the section above.
DRUPAL_JSONAPI_URL=http://my-drupal-site.ddev.site/jsonapi/node/article
DRUPAL_USERNAME=api_user
DRUPAL_PASSWORD=change-me
# Optional — defaults shown:
# DRUPAL_STATE_PATH=drupal_ingestion_state.json
# DRUPAL_PAGE_SIZE=50
# DRUPAL_REQUEST_TIMEOUT=30
# DRUPAL_KG_MIN_CONFIDENCE=0.6

# ── Data sources ────────────────────────────────────────────────────────
DOWNLOADS_DIR=./downloads
ATLASES_DIR=./atlases_pdfs

# Incremental ingestion: content-hash manifest of already-ingested files.
# Files whose SHA-256 hash is recorded here are skipped on re-runs (use
# `python main.py ingest --force` to re-ingest everything).
INGEST_MANIFEST_PATH=./ingest_manifest.json

# ── Chunking ─────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Retrieval ────────────────────────────────────────────────────────────
TOP_K_VECTOR=5
TOP_K_GRAPH=10
GRAPH_DEPTH=2
TOP_K_BM25=5
HYBRID_RRF_K=60

# ── History-aware retrieval & answer quality ─────────────────────────────
# Rewrite follow-ups ("what's its resolution?") into a standalone query using
# recent turns before retrieval. Gated: the LLM rewrite fires only on detected
# follow-ups, so most turns cost nothing.
ENABLE_QUERY_CONTEXTUALIZATION=true
CONTEXTUALIZER_MAX_HISTORY_CHARS=1500
# Embedding-rerank the fused vector+BM25 passages, keep the most relevant few.
ENABLE_PASSAGE_RERANK=true
RERANK_CANDIDATE_POOL=20
TOP_K_PASSAGES=6
# Rolling summary of older turns once history exceeds the recent window (opt-in,
# adds an LLM call on overflow only).
ENABLE_CONVERSATION_SUMMARY=false
SUMMARY_KEEP_RECENT_TURNS=6

# ── ChatAPI gateway (FastAPI HTTP layer — branding, CORS, sessions) ────
CHAT_API_TITLE=Graph RAG Chatbot API
CHAT_API_VERSION=1.0.0
CHAT_API_BOT_NAME=Assistant
CHAT_API_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CHAT_API_ALLOWED_METHODS=GET,POST,DELETE,OPTIONS
CHAT_API_ALLOWED_HEADERS=*
CHAT_API_MAX_HISTORY_TURNS=10
CHAT_API_SESSION_BACKEND=memory
CHAT_API_REDIS_URL=
CHAT_API_ENABLE_SCREENSHOT=true
CHAT_API_MAX_SCREENSHOT_BYTES=8388608
CHAT_API_HOST=0.0.0.0
CHAT_API_PORT=8000
