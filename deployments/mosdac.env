# ─────────────────────────────────────────────────────────────────────────────
# MOSDAC deployment template
# Copy to project root as `.env`, then fill in secrets at the top.
# ─────────────────────────────────────────────────────────────────────────────

# ── LLM: Tabby ML (OpenAI-compatible) ────────────────────────────────────────
TABBY_BASE_URL=http://localhost:8080/v1
TABBY_API_TOKEN=your_tabby_token_here
TABBY_MODEL=Qwen2-1.5B-Instruct

# ISRO production — update values above (no code change needed):
# TABBY_BASE_URL=http://192.168.100.101:8080/v1
# TABBY_API_TOKEN=your_isro_tabby_token_here

# The MOSDAC agent reuses TABBY_* above. To point the agent at a different LLM:
# AGENT_LLM_BASE_URL=...
# AGENT_LLM_API_KEY=...
# AGENT_LLM_MODEL=...

# ── Embeddings: Nomic Embed Text via Tabby ML ─────────────────────────────────
# Reuses TABBY_BASE_URL and TABBY_API_TOKEN by default — no extra credentials
# needed when the embedding model runs on the same Tabby ML server as the LLM.
# Override with NOMIC_BASE_URL / NOMIC_API_TOKEN only for a separate server.
NOMIC_MODEL_NAME=nomic-embed-text
# NOMIC_BASE_URL=http://localhost:8080/v1
# NOMIC_API_TOKEN=your_token_here

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your_secure_password_here
NEO4J_DATABASE=neo4j

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=graph_rag

# ── System prompt (MOSDAC persona) ───────────────────────────────────────────
SYSTEM_PROMPT_PATH=./prompts/system_prompt.txt

# ── OCR (optional fallback for image-only PDFs) ─────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract
POPPLER_PATH=/usr/bin

# ── Data sources ─────────────────────────────────────────────────────────────
DOWNLOADS_DIR=./downloads
ATLASES_DIR=./atlases_pdfs

# ── Chunking ─────────────────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Retrieval ────────────────────────────────────────────────────────────────
TOP_K_VECTOR=5
TOP_K_GRAPH=10
GRAPH_DEPTH=2

# ── MOSDAC Agent ─────────────────────────────────────────────────────────────
MOSDAC_USE_MOCK=false
MOSDAC_USERNAME=your_mosdac_username_here
MOSDAC_PASSWORD=your_mosdac_password_here

# ── ChatAPI gateway (domain-specific branding) ──────────────────────────────
CHAT_API_TITLE=MOSDAC Graph RAG Chatbot API
CHAT_API_VERSION=1.0.0
CHAT_API_BOT_NAME=MOSDAC Assistant
CHAT_API_ALLOWED_ORIGINS=https://www.mosdac.gov.in,https://mosdac.gov.in,http://localhost,http://127.0.0.1
CHAT_API_ALLOWED_METHODS=GET,POST,DELETE,OPTIONS
CHAT_API_ALLOWED_HEADERS=*
CHAT_API_MAX_HISTORY_TURNS=10
CHAT_API_SESSION_BACKEND=memory
CHAT_API_REDIS_URL=
CHAT_API_ENABLE_SCREENSHOT=true
CHAT_API_MAX_SCREENSHOT_BYTES=8388608
CHAT_API_HOST=0.0.0.0
CHAT_API_PORT=8000
