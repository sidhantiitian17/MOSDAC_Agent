# ─────────────────────────────────────────────────────────────────────────────
# Generic deployment template — copy to project root as `.env` and edit.
# ─────────────────────────────────────────────────────────────────────────────

# ── Local LLM ────────────────────────────────────────────────────────────────
QWEN_API_BASE=http://ollama:11434/v1
QWEN_MODEL=qwen2.5vl:7b
QWEN_API_KEY=ollama

# Optional cloud fallbacks
LONGCAT_API_KEY=
LONGCAT_MODEL=LongCat-Flash-Chat
LONGCAT_API_BASE=https://api.longcat.chat/openai
LONGCAT_API_FORMAT=openai

# ── Embeddings ───────────────────────────────────────────────────────────────
GEMINI_EMBEDDING_MODEL=models/gemini-embedding-001
GEMINI_API_KEY=
NVIDIA_EMBEDDING_MODEL=nvidia/llama-nemotron-embed-1b-v2
NVIDIA_API_KEY=

# ── Neo4j ────────────────────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change_me
NEO4J_DATABASE=neo4j

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION=graph_rag

# ── System prompt (point at your own file for a different persona) ─────────
SYSTEM_PROMPT_PATH=./prompts/system_prompt.txt

# ── OCR (optional) ──────────────────────────────────────────────────────────
TESSERACT_CMD=/usr/bin/tesseract
POPPLER_PATH=/usr/bin

# ── Data sources ─────────────────────────────────────────────────────────────
DOWNLOADS_DIR=./downloads
ATLASES_DIR=./atlases_pdfs

# ── Chunking & retrieval ────────────────────────────────────────────────────
CHUNK_SIZE=800
CHUNK_OVERLAP=100
TOP_K_VECTOR=5
TOP_K_GRAPH=10
GRAPH_DEPTH=2

# ── ChatAPI gateway (customise per portal) ──────────────────────────────────
CHAT_API_TITLE=Graph RAG Chatbot API
CHAT_API_VERSION=1.0.0
CHAT_API_BOT_NAME=Assistant
CHAT_API_ALLOWED_ORIGINS=http://localhost,http://127.0.0.1
CHAT_API_ALLOWED_METHODS=GET,POST,DELETE,OPTIONS
CHAT_API_ALLOWED_HEADERS=*
CHAT_API_MAX_HISTORY_TURNS=10
CHAT_API_SESSION_BACKEND=memory
CHAT_API_REDIS_URL=
CHAT_API_ENABLE_SCREENSHOT=true
CHAT_API_MAX_SCREENSHOT_BYTES=8388608
CHAT_API_HOST=0.0.0.0
CHAT_API_PORT=8000
